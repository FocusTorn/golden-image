<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options" 
        Width="760"
        MinHeight="400"
        Height="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- ToggleSwitch style: pill track + sliding thumb (Windows 11 style) -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="44" Height="24" CornerRadius="12" Background="{DynamicResource ComboBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Margin="3" HorizontalAlignment="Left" Fill="White">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ComboHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sidebar section item style - no background card -->
        <Style x:Key="SidebarSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ComboHoverColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border BorderBrush="{DynamicResource BorderColor}" 
            BorderThickness="1" 
            CornerRadius="8"
            Background="{DynamicResource CardBgColor}"
            Margin="25">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Opacity="0.15" 
                            BlurRadius="20" 
                            ShadowDepth="0" 
                            Direction="0"/>
        </Border.Effect>
        
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" x:Name="TitleBar" Height="44" Background="Transparent">
                <TextBlock x:Name="TitleText" 
                           Text="Options" 
                           Foreground="{DynamicResource FgColor}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" 
                           Margin="20,0,0,0"/>
            </Grid>

            <!-- Main content: Sidebar + Content area (same BG, no divider) -->
            <Grid Grid.Row="1" Margin="0,8,0,0" Background="{DynamicResource BgColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar with sections - width fits content -->
                <Border Grid.Column="0" Background="{DynamicResource BgColor}" Padding="12,8,4,16">
                    <StackPanel>
                        <Border x:Name="SidebarSectionGeneral" Style="{StaticResource SidebarSectionStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource FgColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="General" Foreground="{DynamicResource FgColor}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Content area - row cards -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="8,8,20,20" Background="{DynamicResource BgColor}">
                    <StackPanel x:Name="OptionsContentPanel">
                        <!-- Section heading -->
                        <TextBlock Text="Window behavior" 
                                  Foreground="{DynamicResource FgColor}" 
                                  FontSize="12" 
                                  FontWeight="SemiBold" 
                                  Margin="0,0,0,12"
                                  Opacity="0.9"/>
                        <!-- Row card: Hide launcher window -->
                        <Border Background="{DynamicResource ComboBgColor}" 
                                BorderBrush="{DynamicResource BorderColor}" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="16,14" 
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="&#xE8C8;" 
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="20"
                                           Foreground="{DynamicResource FgColor}"
                                           VerticalAlignment="Top"
                                           Margin="0,2,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock x:Name="OptionsHideLauncherLabel"
                                               Text="Hide launcher window"
                                               Foreground="{DynamicResource FgColor}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="Hide the PowerShell console when the app is open. Only works when launched from a console (e.g. powershell.exe)."
                                               Foreground="{DynamicResource FgColor}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="OptionsHideLauncherToggle"
                                             Grid.Column="2"
                                             Style="{StaticResource ToggleSwitchStyle}"
                                             VerticalAlignment="Center"
                                             IsHitTestVisible="True"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Button Panel -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource BgColor}"
                    BorderThickness="0"
                    Padding="16,12"
                    CornerRadius="0,0,8,8">
                <StackPanel x:Name="ButtonPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="OptionsOkButton" 
                            Content="OK" 
                            Height="32" MinWidth="80" Margin="4,0"
                            Style="{DynamicResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
